HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=https://your-domain.example
TRUST_PROXY=false
REQUIRE_HTTPS=false

ADMIN_ENABLED=true
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-this-long-random-password
ADMIN_ALLOWED_IPS=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
ADMIN_RATE_LIMIT_MAX=60
REQUEST_LOG_LIMIT=200
LOG_TO_FILE=true
LOG_DIR=logs

ORDER_NOTIFICATION_SECRET=change-this-long-random-shared-secret
SHOP_NAME=PopOutPick

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=orders@example.com
SMTP_PASS=change-this-smtp-password
SMTP_FROM=orders@example.com

TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_ADMIN_CHAT_ID=replace-with-your-chat-id
TELEGRAM_WEBHOOK_SECRET=change-this-long-random-telegram-secret
TELEGRAM_CUSTOMER_CHAT_MAP_FILE=data/telegram-chat-map.json

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-this-service-role-key

# Required when checkout pages are served from a different origin than this backend.
# Example: CHECKOUT_ALLOWED_ORIGINS=https://your-github-username.github.io,https://www.your-domain.example
CHECKOUT_ALLOWED_ORIGINS=
CHECKOUT_UPLOAD_MAX_BYTES=20971520
CHECKOUT_REQUEST_MAX_BYTES=83886080

# Optional HTTPS files, relative to this folder.
# HTTPS_KEY_PATH=certs/privkey.pem
# HTTPS_CERT_PATH=certs/fullchain.pem
